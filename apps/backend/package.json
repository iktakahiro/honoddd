{
  "name": "@honoddd/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build ./src/index.ts --target bun --outdir dist --external @honoddd/contract",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "test": "bun test",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "typecheck": "bun run type-check",
    "check": "bun run type-check && bun run test"
  },
  "dependencies": {
    "@electric-sql/pglite": "0.4.5",
    "@honoddd/contract": "workspace:*",
    "@orpc/openapi": "1.14.3",
    "@orpc/server": "1.14.3",
    "@orpc/zod": "1.14.3",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.22",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@honoddd/typescript-config": "workspace:*",
    "drizzle-kit": "0.31.10"
  }
}
