{
  "name": "@honoddd/contract",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --target bun --outdir dist --external @orpc/contract --external @orpc/openapi --external @orpc/zod --external zod",
    "test": "bun test",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "typecheck": "bun run type-check",
    "check": "bun run type-check && bun run test"
  },
  "dependencies": {
    "@orpc/contract": "1.14.3",
    "@orpc/openapi": "1.14.3",
    "@orpc/zod": "1.14.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@honoddd/typescript-config": "workspace:*"
  }
}
