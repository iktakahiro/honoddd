{
  "name": "honoddd",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "dev:backend": "turbo run dev --filter=@honoddd/backend",
    "dev:api-doc": "turbo run dev --filter=@honoddd/api-doc",
    "build": "turbo run build",
    "type-check": "turbo run type-check",
    "typecheck": "bun run type-check",
    "test": "turbo run test",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "check": "turbo run check",
    "check:fix": "bun run fix",
    "validate": "turbo run build check",
    "fix": "turbo run quality:fix",
    "deps:check": "bunx npm-check-updates"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "bun-types": "1.3.14",
    "npm-check-updates": "22.2.3",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "turbo": "2.9.18",
    "typescript": "6.0.3"
  },
  "overrides": {
    "esbuild": "0.25.12"
  },
  "packageManager": "bun@1.3.14"
}
